<main class="content">
    <div class="content__wrapper" style="max-width: 800px; margin: 3rem auto; padding: 0 1.5rem;">
        <h1 style="font-size: 2.2rem; font-weight: 800; color: var(--text-main); margin-bottom: 2rem;">
            <%= infoTitle %>
        </h1>
        <div class="info-content"
            style="background: var(--surface); padding: 2rem; border-radius: 12px; border: 1px solid var(--border); line-height: 1.8; color: var(--text-main); font-size: 1.05rem;">
            <%- infoContent %>
        </div>
    </div>
</main>