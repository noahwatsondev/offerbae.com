<section class="content-section">
    <div class="product-details-container">
        <% if (typeof productDetails !='undefined' && productDetails) { %>

            <!-- SEO: Structured Data for Google -->
            <script type="application/ld+json">
            {
                "@context": "https://schema.org/",
                "@type": "Product",
                "name": "<%- productDetails.name.replace(/"/g, '\\"') %>",
                "image": "<%- productDetails.imageUrl %>",
                <% if (productDetails.longDescription || productDetails.description) { %>
                "description": "<%- (productDetails.longDescription || productDetails.description).replace(/(<([^>]+)>)/gi, "").replace(/"/g, '\\"').substring(0, 300) %>...",
                <% } %>
                "sku": "<%- productDetails.sku %>",
                "brand": {
                    "@type": "Brand",
                    "name": "<%- productDetails.brandName %>"
                },
                "offers": {
                    "@type": "Offer",
                    "url": "<%- productDetails.link %>",
                    "priceCurrency": "USD",
                    "price": "<%- productDetails.salePrice || productDetails.price || 0 %>",
                    "itemCondition": "https://schema.org/NewCondition",
                    "availability": "https://schema.org/InStock",
                    "seller": {
                        "@type": "Organization",
                        "name": "<%- productDetails.brandName %>"
                    }
                }<% if (productDetails.rating && productDetails.reviewCount) { %>,
                "aggregateRating": {
                    "@type": "AggregateRating",
                    "ratingValue": "<%- productDetails.rating %>",
                    "reviewCount": "<%- productDetails.reviewCount %>"
                }
                <% } %>
            }
            </script>

            <!-- ZONE 1: Image + Price + Buy + Description -->

            <div class="product-body">

                <!-- Image -->
                <div class="pdp-image-col">
                    <div class="pdp-image-wrap">
                        <% if (typeof productDetails.discountPercent !== 'undefined' && productDetails.discountPercent > 0) { %>
                            <div class="pdp-discount-badge"><%= productDetails.discountPercent %>% OFF</div>
                        <% } %>
                        <a href="<%= productDetails.link || '#' %>" target="_blank" rel="noopener noreferrer">
                            <img src="<%= productDetails.imageUrl %>" alt="<%= productDetails.name %>"
                                class="pdp-image" onerror="this.style.display='none'">
                        </a>
                    </div>
                </div>

                
                <div class="pdp-info-col">

                    
                    <h1 class="pdp-title">
                        <%= productDetails.name %>
                    </h1>

                    <% if (typeof productDetails.rating !== 'undefined' && productDetails.rating) { %>
                        <div class="pdp-rating">
                            <div class="stars">
                                <% for(let i=1; i<=5; i++) { %>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="<%= i <= Math.round(productDetails.rating) ? '#fbbf24' : '#e5e7eb' %>" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                <% } %>
                            </div>
                            <span class="rating-value"><%= productDetails.rating %></span>
                            <% if (productDetails.reviewCount) { %>
                                <span class="review-count">(<%= productDetails.reviewCount.toLocaleString() %> reviews)</span>
                            <% } %>
                        </div>
                    <% } %>

                    <div class="pdp-price-block">
                        <% 
                            const _pPrice = Number(productDetails.price || 0);
                            const _pSale = Number(productDetails.salePrice || 0);
                            const _pHasDeal = _pPrice > _pSale && _pSale > 0;
                            const _pDisplay = _pHasDeal ? _pSale : (_pSale > 0 ? _pSale : _pPrice);
                        %>
                        <span class="pdp-price<%= _pHasDeal ? ' is-sale' : '' %>">
                            $<%= _pDisplay.toFixed(2) %>
                        </span>
                        <% if (_pHasDeal) { %>
                            <span class="pdp-original-price">$<%= _pPrice.toFixed(2) %></span>
                            <span class="pdp-savings">Save <%= Math.round((1 - (_pSale / _pPrice)) * 100) %>%</span>
                        <% } %>
                    </div>

                    <a href="<%= productDetails.link || '#' %>" target="_blank" rel="noopener noreferrer"
                        class="btn-primary pdp-cta">
                        Buy from <%= productDetails.brandName %> &rarr;
                    </a>


                    <% if (productDetails.longDescription || productDetails.description) { %>
                        <div class="pdp-description">
                            <h2 class="pdp-section-heading">About this item</h2>
                            <div class="pdp-desc-content">
                                <%- productDetails.longDescription || productDetails.description %>
                            </div>
                        </div>
                    <% } %>

                    <% if (productDetails.ingredients) { %>
                        <div class="pdp-ingredients">
                            <h2 class="pdp-section-heading">Ingredients</h2>
                            <p class="pdp-ingredients-text"><%= productDetails.ingredients %></p>
                        </div>
                    <% } %>

                    <% if (productDetails.specifications && Object.keys(productDetails.specifications).length > 0) { %>
                        <div class="pdp-specs-full">
                            <h2 class="pdp-section-heading">Full Specifications</h2>
                            <div class="pdp-specs-grid">
                                <% Object.entries(productDetails.specifications).forEach(([key, val]) => { %>
                                    <div class="spec-item">
                                        <span class="spec-label"><%= key %></span>
                                        <span class="spec-value"><%= val %></span>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>

                    <% if (productDetails.rating && productDetails.reviewCount) { %>
                        <div class="pdp-reviews-section">
                            <h2 class="pdp-section-heading">Customer Reviews</h2>
                            <div class="pdp-reviews-summary">
                                <div class="review-score-big">
                                    <span class="score-number"><%= productDetails.rating %></span>
                                    <span class="score-out-of">/ 5</span>
                                </div>
                                <div class="review-stars-big">
                                    <div class="stars">
                                        <% for(let i=1; i<=5; i++) { %>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="<%= i <= Math.round(productDetails.rating) ? '#fbbf24' : '#e5e7eb' %>" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        <% } %>
                                    </div>
                                    <div class="review-count-text">Based on <%= productDetails.reviewCount.toLocaleString() %> verified ratings across the web</div>
                                </div>
                            </div>
                            
                            <% if (productDetails.reviews_url) { %>
                                <div class="pdp-reviews-cta">
                                    <p>We've captured and aggregated trusted feedback from multiple retailers to ensure you have the full picture.</p>
                                    <a href="<%= productDetails.reviews_url %>" target="_blank" rel="noopener noreferrer" class="pdp-review-btn">
                                        Read All <%= productDetails.reviewCount.toLocaleString() %> Detailed Reviews &rarr;
                                    </a>
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                    
                    <div class="pdp-details-grid">
                        <h2 class="pdp-section-heading">Product details</h2>
                        <dl class="pdp-details-dl">
                            <% if (productDetails.brandName) { %>
                                <div class="pdp-detail-row">
                                    <dt>Brand</dt>
                                    <dd>
                                        <% if (typeof brandWebsiteUrl !== 'undefined' && brandWebsiteUrl) { %>
                                            <a href="<%= brandWebsiteUrl %>" target="_blank" rel="noopener noreferrer"><%= productDetails.brandName %></a>
                                        <% } else { %>
                                            <%= productDetails.brandName %>
                                        <% } %>
                                    </dd>
                                </div>
                            <% } %>
                            <% if (productDetails.sku) { %>
                                <div class="pdp-detail-row">
                                    <dt>SKU</dt>
                                    <dd><%= productDetails.sku %></dd>
                                </div>
                            <% } %>
                            <% if (productDetails.primaryCategory || productDetails.category) { %>
                                <div class="pdp-detail-row">
                                    <dt>Category</dt>
                                    <dd><%= productDetails.primaryCategory || productDetails.category %></dd>
                                </div>
                            <% } %>
                            <% if (typeof brandNetwork !== 'undefined' && brandNetwork) { %>
                                <div class="pdp-detail-row">
                                    <dt>Store network</dt>
                                    <dd><%= brandNetwork %></dd>
                                </div>
                            <% } %>
                            <% if (productDetails.updatedAt) { %>
                                <div class="pdp-detail-row">
                                    <dt>Price last updated</dt>
                                    <dd><%= new Date(productDetails.updatedAt.toDate ? productDetails.updatedAt.toDate() : productDetails.updatedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></dd>
                                </div>
                            <% } %>
                        </dl>
                    </div>

                </div>
            </div>

            <!-- ZONE 2: Brand Description -->
            <% if (typeof brandDescription !== 'undefined' && brandDescription) { %>
                <div class="pdp-brand-about">
                    <h2 class="pdp-section-heading">About <%= productDetails.brandName %></h2>
                    <div class="pdp-brand-about-body">
                        <% if (typeof pageLogo !== 'undefined' && pageLogo) { %>
                            <img src="<%= pageLogo %>" alt="<%= productDetails.brandName %>" class="pdp-brand-logo-inline">
                        <% } %>
                        <div class="pdp-brand-about-text"><%- brandDescription %></div>
                    </div>
                    <% if (typeof brandWebsiteUrl !== 'undefined' && brandWebsiteUrl) { %>
                        <a href="<%= brandWebsiteUrl %>" target="_blank" rel="noopener noreferrer" class="pdp-brand-link">
                            Visit <%= productDetails.brandName %> &rarr;
                        </a>
                    <% } %>
                </div>
            <% } %>

            <!-- ZONE 3: Related Products -->
            <% const _relatedProds = (typeof relatedProducts !== 'undefined' && relatedProducts && relatedProducts.length > 0) ? relatedProducts : []; %>
            <% if (_relatedProds.length > 0) { %>
                <div class="pdp-related">
                    <h2 class="pdp-section-heading">More from <%= productDetails.brandName %></h2>
                    <div class="pdp-related-grid">
                        <% _relatedProds.forEach(function(p) {
                            const _rOrig = Number(p.price || 0);
                            const _rSale = Number(p.salePrice || 0);
                            const _rHasDeal = _rOrig > _rSale && _rSale > 0;
                            const _rDisplay = _rHasDeal ? _rSale : (_rSale > 0 ? _rSale : _rOrig);
                        %>
                            <a href="/products/<%= p.brandSlug || productDetails.brandSlug %>/<%= p.slug %>"
                               class="pdp-related-card">
                                <% const _img = p.storageImageUrl || p.imageUrl; %>
                                <% if (_img) { %>
                                    <div class="pdp-related-img-wrap">
                                        <img src="<%= _img %>" alt="<%= p.name %>" loading="lazy" onerror="this.parentElement.style.display='none'">
                                    </div>
                                <% } %>
                                <div class="pdp-related-info">
                                    <div class="pdp-related-name"><%= (p.name || '').substring(0, 60) %><%= (p.name || '').length > 60 ? '…' : '' %></div>
                                    <% if (_rDisplay > 0) { %>
                                        <div class="pdp-related-price<%= _rHasDeal ? ' is-sale' : '' %>">
                                            $<%= _rDisplay.toFixed(2) %>
                                            <% if (_rHasDeal) { %><span class="pdp-related-original">$<%= _rOrig.toFixed(2) %></span><% } %>
                                        </div>
                                    <% } %>
                                </div>
                            </a>
                        <% }); %>
                    </div>
                </div>
            <% } %>

        <% } else { %>
            <p>Product details not available.</p>
        <% } %>
    </div>
</section>