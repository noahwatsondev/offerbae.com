<section class="content-section">
    <div class="product-details-container">
        <% if (typeof productDetails !=='undefined' && productDetails) { %>
            <div class="product-header">
                <h2>
                    <%= productDetails.name %>
                </h2>
                <div class="product-meta">By <%= productDetails.brandName %>
                </div>
            </div>
            <div class="product-body" style="display:flex; gap:2rem; margin-top:2rem;">
                <div class="product-image" style="flex:1;">
                    <img src="<%= productDetails.imageUrl %>" alt="<%= productDetails.name %>"
                        style="max-width:100%; height:auto;">
                </div>
                <div class="product-info" style="flex:1;">
                    <div class="price-block">
                        <span class="current-price" style="font-size:2rem; font-weight:bold;">$<%= productDetails.price
                                %></span>
                        <% if (productDetails.salePrice) { %>
                            <span class="sale-price"
                                style="text-decoration:line-through; color:#888; margin-left:1rem;">$<%=
                                    productDetails.salePrice %></span>
                            <% } %>
                    </div>
                    <p class="description" style="margin-top:1rem;">
                        <%= productDetails.description || 'No description available.' %>
                    </p>
                    <a href="<%= productDetails.affiliateUrl || '#' %>" target="_blank" class="btn-primary"
                        style="display:inline-block; margin-top:2rem; padding:1rem 2rem; background:var(--primary-color); color:white; text-decoration:none; border-radius:0.5rem;">Buy
                        Now</a>
                </div>
            </div>
            <% } else { %>
                <p>Product details not available.</p>
                <% } %>
    </div>
</section>