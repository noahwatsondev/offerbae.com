<section class="content-section">
    <div class="product-details-container">
        <% if (typeof productDetails !='undefined' && productDetails) { %>

            <!-- ZONE 1: Image + Price + Buy + Description -->

            <div class="product-body">

                <!-- Image -->
                <div class="pdp-image-col">
                    <div class="pdp-image-wrap">
                        <% if (typeof productDetails.discountPercent !== 'undefined' && productDetails.discountPercent > 0) { %>
                            <div class="pdp-discount-badge"><%= productDetails.discountPercent %>% OFF</div>
                        <% } %>
                        <a href="<%= productDetails.link || '#' %>" target="_blank" rel="noopener noreferrer">
                            <img src="<%= productDetails.imageUrl %>" alt="<%= productDetails.name %>"
                                class="pdp-image" onerror="this.style.display='none'">
                        </a>
                    </div>
                </div>

                
                <div class="pdp-info-col">

                    
                    <% const _orig = Number(productDetails.price || 0);
                       const _sale = Number(productDetails.salePrice || 0);
                       const _hasDeal = _orig > _sale && _sale > 0;
                       const _display = _hasDeal ? _sale : (_sale > 0 ? _sale : _orig); %>
                    <div class="pdp-price-block">
                        <span class="pdp-price<%= _hasDeal ? ' is-sale' : '' %>">$<%= _display.toFixed(2) %></span>
                        <% if (_hasDeal) { %>
                            <span class="pdp-original-price">$<%= _orig.toFixed(2) %></span>
                            <span class="pdp-savings">You save $<%= (_orig - _sale).toFixed(2) %></span>
                        <% } %>
                    </div>

                    
                    <a href="<%= productDetails.link || '#' %>" target="_blank" rel="noopener noreferrer"
                        class="btn-primary pdp-cta">
                        Shop Now &rarr;
                    </a>

                    
                    <% const _pdpOffers = (typeof sidebarData !== 'undefined' && sidebarData.newestOffers) ? sidebarData.newestOffers : []; %>
                    <% if (_pdpOffers.length > 0) { %>
                        <div class="pdp-offers-stripe">
                            <div class="pdp-offers-label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.91 8.84 8.56 2.23a1.93 1.93 0 0 0-1.81 0L3.1 4.13a2.12 2.12 0 0 0-.05 3.69l12.22 6.73a1.47 1.47 0 0 0 1.39 0l3.7-2.04a2.12 2.12 0 0 0 .55-3.67z"/><path d="m3 13 13.5 7.7a2 2 0 0 0 1.8 0L21 19"/></svg>
                                Active deals for this brand
                            </div>
                            <div class="pdp-offers-chips">
                                <% _pdpOffers.slice(0, 5).forEach(function(o) { %>
                                    <a href="<%= o.clickUrl || '#' %>" target="_blank" rel="noopener noreferrer"
                                       class="pdp-offer-chip<%= o.isPromoCode ? ' has-code' : '' %>">
                                        <% if (o.isPromoCode && o.code && o.code !== 'N/A') { %>
                                            <span class="chip-code"><%= o.code %></span>
                                        <% } %>
                                        <span class="chip-desc"><%= (o.description || '').substring(0, 48) %><%= (o.description || '').length > 48 ? '…' : '' %></span>
                                    </a>
                                <% }); %>
                                <% if (typeof brandSlug !== 'undefined' && brandSlug) { %>
                                    <a href="/offers/<%= productDetails.brandSlug || brandSlug %>" class="pdp-offer-see-all">All deals &rarr;</a>
                                <% } %>
                            </div>
                        </div>
                    <% } %>

                    
                    <% if (productDetails.description) { %>
                        <div class="pdp-description">
                            <h2 class="pdp-section-heading">About this item</h2>
                            <p><%= productDetails.description %></p>
                        </div>
                    <% } %>

                    
                    <div class="pdp-details-grid">
                        <h2 class="pdp-section-heading">Product details</h2>
                        <dl class="pdp-details-dl">
                            <% if (productDetails.brandName) { %>
                                <div class="pdp-detail-row">
                                    <dt>Brand</dt>
                                    <dd>
                                        <% if (typeof brandWebsiteUrl !== 'undefined' && brandWebsiteUrl) { %>
                                            <a href="<%= brandWebsiteUrl %>" target="_blank" rel="noopener noreferrer"><%= productDetails.brandName %></a>
                                        <% } else { %>
                                            <%= productDetails.brandName %>
                                        <% } %>
                                    </dd>
                                </div>
                            <% } %>
                            <% if (productDetails.sku) { %>
                                <div class="pdp-detail-row">
                                    <dt>SKU</dt>
                                    <dd><%= productDetails.sku %></dd>
                                </div>
                            <% } %>
                            <% if (productDetails.primaryCategory || productDetails.category) { %>
                                <div class="pdp-detail-row">
                                    <dt>Category</dt>
                                    <dd><%= productDetails.primaryCategory || productDetails.category %></dd>
                                </div>
                            <% } %>
                            <% if (typeof brandNetwork !== 'undefined' && brandNetwork) { %>
                                <div class="pdp-detail-row">
                                    <dt>Store network</dt>
                                    <dd><%= brandNetwork %></dd>
                                </div>
                            <% } %>
                            <% if (productDetails.updatedAt) { %>
                                <div class="pdp-detail-row">
                                    <dt>Price last updated</dt>
                                    <dd><%= new Date(productDetails.updatedAt.toDate ? productDetails.updatedAt.toDate() : productDetails.updatedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></dd>
                                </div>
                            <% } %>
                        </dl>
                    </div>

                </div>
            </div>

            <!-- ZONE 2: Brand Description -->
            <% if (typeof brandDescription !== 'undefined' && brandDescription) { %>
                <div class="pdp-brand-about">
                    <h2 class="pdp-section-heading">About <%= productDetails.brandName %></h2>
                    <div class="pdp-brand-about-body">
                        <% if (typeof pageLogo !== 'undefined' && pageLogo) { %>
                            <img src="<%= pageLogo %>" alt="<%= productDetails.brandName %>" class="pdp-brand-logo-inline">
                        <% } %>
                        <div class="pdp-brand-about-text"><%- brandDescription %></div>
                    </div>
                    <% if (typeof brandWebsiteUrl !== 'undefined' && brandWebsiteUrl) { %>
                        <a href="<%= brandWebsiteUrl %>" target="_blank" rel="noopener noreferrer" class="pdp-brand-link">
                            Visit <%= productDetails.brandName %> &rarr;
                        </a>
                    <% } %>
                </div>
            <% } %>

            <!-- ZONE 3: Related Products -->
            <% const _relatedProds = (typeof sidebarData !== 'undefined' && sidebarData.newestProducts && sidebarData.newestProducts.length > 0) ? sidebarData.newestProducts : []; %>
            <% if (_relatedProds.length > 0) { %>
                <div class="pdp-related">
                    <h2 class="pdp-section-heading">More from <%= productDetails.brandName %></h2>
                    <div class="pdp-related-scroll">
                        <% _relatedProds.forEach(function(p) {
                            const _rOrig = Number(p.price || 0);
                            const _rSale = Number(p.salePrice || 0);
                            const _rHasDeal = _rOrig > _rSale && _rSale > 0;
                            const _rDisplay = _rHasDeal ? _rSale : (_rSale > 0 ? _rSale : _rOrig);
                        %>
                            <a href="/products/<%= p.brandSlug || productDetails.brandSlug %>/<%= p.slug %>"
                               class="pdp-related-card">
                                <% const _img = p.storageImageUrl || p.imageUrl; %>
                                <% if (_img) { %>
                                    <div class="pdp-related-img-wrap">
                                        <img src="<%= _img %>" alt="<%= p.name %>" loading="lazy" onerror="this.parentElement.style.display='none'">
                                    </div>
                                <% } %>
                                <div class="pdp-related-info">
                                    <div class="pdp-related-name"><%= (p.name || '').substring(0, 60) %><%= (p.name || '').length > 60 ? '…' : '' %></div>
                                    <% if (_rDisplay > 0) { %>
                                        <div class="pdp-related-price<%= _rHasDeal ? ' is-sale' : '' %>">
                                            $<%= _rDisplay.toFixed(2) %>
                                            <% if (_rHasDeal) { %><span class="pdp-related-original">$<%= _rOrig.toFixed(2) %></span><% } %>
                                        </div>
                                    <% } %>
                                </div>
                            </a>
                        <% }); %>
                    </div>
                </div>
            <% } %>

        <% } else { %>
            <p>Product details not available.</p>
        <% } %>
    </div>
</section>