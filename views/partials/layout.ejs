<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <% if (typeof metaTitle !=='undefined' && metaTitle) { %>
            <%= metaTitle %>
                <% } else { %>
                    <% var _titleBase=(typeof pageH1 !='undefined' && pageH1) ? pageH1 : '' ; var _titleSub=(typeof
                        pageH1Sub !='undefined' && pageH1Sub) ? ' ' + pageH1Sub : '' ; var _fullTitle='OfferBae.com' ;
                        if (_titleBase || _titleSub) { _fullTitle=_titleBase + _titleSub + ' - OfferBae.com' ; } %>
                        <%= _fullTitle %>
                            <% } %>
    </title>
    <% const cssVersion=process.env.CSS_VERSION || '1' ; %>
        <link rel="preload" href="/css/layout/main.css?v=<%= cssVersion %>" as="style">
        <link rel="stylesheet" href="/css/layout/main.css?v=<%= cssVersion %>">

        <% if (typeof settings !='undefined' ) { %>
            <style>
                :root {
                    /* Fallback to default SCSS variables if not set */
                    --primary-color: <%=settings.defaultLinkColor || '#4f46e5' %>;
                    --bg-color: <%=settings.bgColor || '#f9fafb' %>;
                    --nav-link-color: <%=settings.headerNavLinksColor || '#111827' %>;

                    /* Color Spectrum */
                    --color-red: <%=settings.colorRed || '#ef4444' %>;
                    --color-orange: <%=settings.colorOrange || '#f97316' %>;
                    --color-yellow: <%=settings.colorYellow || '#eab308' %>;
                    --color-green: <%=settings.colorGreen || '#22c55e' %>;
                    --color-blue: <%=settings.colorBlue || '#3b82f6' %>;
                    --color-violet: <%=settings.colorViolet || '#8b5cf6' %>;
                }

                body {
                    background-color: var(--bg-color);
                }
            </style>
            <% } %>

                <%- include('header-scripts') %>
</head>

<body>
    <% if (typeof settings !='undefined' && settings.bgImageUrl) { %>
        <div class="bg-fixed-layer" style="background-image: url('<%= settings.bgImageUrl %>');"></div>
        <% } %>

            <div class="layout">
                <%- include('header', { settings: typeof settings !='undefined' ? settings : {} }) %>
                    <%- include('breadcrumbs') %>
                        <%- include('context') %>
                            <%- include('sidebar') %>
                                <%- include(typeof mainPartial !='undefined' ? mainPartial : 'main-container' ) %>
                                    <%- include('footer') %>
            </div>
            <%- include('footer-scripts') %>
                <%- include('section-offer-modal') %>
</body>

</html>