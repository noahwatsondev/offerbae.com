<%# Offer Detail Modal — rendered server-side when `modalOffer` is present, shown via JS on load %>
    <% if (typeof modalOffer !=='undefined' && modalOffer) { %>
        <script>window.__MODAL_OFFER__ = <%-JSON.stringify(modalOffer)%>;</script>
        <% } %>

            <div id="offer-modal" class="offer-modal-overlay" style="display:none;" aria-modal="true" role="dialog">
                <div class="offer-modal-backdrop" id="offer-modal-backdrop"></div>
                <div class="offer-modal-card">
                    <div class="offer-modal-header-actions">
                        <button class="offer-modal-share" id="offer-modal-share" aria-label="Share"
                            title="Copy link to this offer" onclick="offerModalShare()">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <circle cx="18" cy="5" r="3" />
                                <circle cx="6" cy="12" r="3" />
                                <circle cx="18" cy="19" r="3" />
                                <line x1="8.59" x2="15.42" y1="13.51" y2="17.49" />
                                <line x1="15.41" x2="8.59" y1="6.51" y2="10.49" />
                            </svg>
                        </button>
                        <button class="offer-modal-close" id="offer-modal-close" aria-label="Close">&times;</button>
                    </div>

                    <div class="offer-modal-brand" id="offer-modal-brand">
                        <div id="offer-modal-logo-wrap" class="offer-modal-logo-wrap" style="display:none;">
                            <img id="offer-modal-logo" src="" alt="Brand Logo">
                        </div>
                        <span id="offer-modal-brand-name" class="offer-modal-brand-name"></span>
                    </div>

                    <div id="offer-modal-type-badge" class="offer-modal-type-badge"></div>

                    <p id="offer-modal-title" class="offer-modal-title"></p>

                    <div id="offer-modal-code-section" class="offer-modal-code-section" style="display:none;">
                        <div class="offer-modal-code-label">Promo Code</div>
                        <div class="offer-modal-code-row">
                            <span id="offer-modal-code" class="offer-modal-code-box"></span>
                            <button id="offer-modal-copy-btn" class="offer-modal-copy-btn"
                                onclick="offerModalCopyCode()">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                                    <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
                                </svg>
                                Copy Code
                            </button>
                        </div>
                    </div>

                    <div class="offer-modal-actions">
                        <a id="offer-modal-btn" href="#" target="_blank" rel="noopener noreferrer"
                            class="offer-modal-get-deal-btn">
                            Get Deal &rarr;
                        </a>
                    </div>

                    <div id="offer-modal-expiry" class="offer-modal-expiry"></div>
                </div>
            </div>

            <style>
                .offer-modal-overlay {
                    position: fixed;
                    inset: 0;
                    z-index: 9999;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                .offer-modal-backdrop {
                    position: absolute;
                    inset: 0;
                    background: rgba(0, 0, 0, 0.55);
                    backdrop-filter: blur(4px);
                    cursor: pointer;
                }

                .offer-modal-card {
                    position: relative;
                    z-index: 1;
                    background: #fff;
                    border-radius: 16px;
                    padding: 2.5rem 2rem 2rem;
                    max-width: 480px;
                    width: calc(100% - 2rem);
                    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
                    animation: modalSlideIn 0.22s cubic-bezier(0.4, 0, 0.2, 1) both;
                }

                @keyframes modalSlideIn {
                    from {
                        opacity: 0;
                        transform: translateY(24px) scale(0.97);
                    }

                    to {
                        opacity: 1;
                        transform: translateY(0) scale(1);
                    }
                }

                .offer-modal-header-actions {
                    position: absolute;
                    top: 1rem;
                    right: 1rem;
                    display: flex;
                    align-items: center;
                    gap: 0.5rem;
                }

                .offer-modal-share,
                .offer-modal-close {
                    background: none;
                    border: none;
                    cursor: pointer;
                    color: #9ca3af;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    padding: 0.25rem;
                    border-radius: 6px;
                    transition: color 0.15s, background 0.15s;
                    line-height: 1;
                }

                .offer-modal-close {
                    font-size: 1.75rem;
                }

                .offer-modal-share:hover,
                .offer-modal-close:hover {
                    color: #111827;
                    background: #f3f4f6;
                }

                .offer-modal-brand {
                    display: flex;
                    align-items: center;
                    gap: 0.85rem;
                    margin-bottom: 1rem;
                }

                .offer-modal-logo-wrap {
                    width: 44px;
                    height: 44px;
                    background: #f3f4f6;
                    border-radius: 8px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    overflow: hidden;
                    flex-shrink: 0;
                }

                .offer-modal-logo-wrap img {
                    max-width: 100%;
                    max-height: 100%;
                    object-fit: contain;
                }

                .offer-modal-brand-name {
                    font-size: 0.8rem;
                    font-weight: 700;
                    color: #6b7280;
                    text-transform: uppercase;
                    letter-spacing: 0.06em;
                }

                .offer-modal-type-badge {
                    display: inline-block;
                    font-size: 0.7rem;
                    font-weight: 800;
                    padding: 0.2rem 0.6rem;
                    border-radius: 100px;
                    margin-bottom: 0.85rem;
                    text-transform: uppercase;
                    letter-spacing: 0.05em;
                }

                .offer-modal-type-badge.is-code {
                    background: color-mix(in srgb, var(--color-violet, #8b5cf6), transparent 85%);
                    color: var(--color-violet, #8b5cf6);
                }

                .offer-modal-type-badge.is-deal {
                    background: color-mix(in srgb, var(--color-green, #22c55e), transparent 85%);
                    color: var(--color-green, #22c55e);
                }

                .offer-modal-title {
                    display: block;
                    font-size: 1.25rem;
                    font-weight: 700;
                    color: #111827;
                    background: none;
                    -webkit-background-clip: unset;
                    -webkit-text-fill-color: #111827;
                    background-clip: unset;
                    filter: none;
                    margin: 0 0 1.5rem 0;
                    line-height: 1.4;
                }

                .offer-modal-code-section {
                    margin-bottom: 1.5rem;
                }

                .offer-modal-code-label {
                    font-size: 0.75rem;
                    font-weight: 600;
                    color: #6b7280;
                    text-transform: uppercase;
                    letter-spacing: 0.05em;
                    margin-bottom: 0.5rem;
                }

                .offer-modal-code-row {
                    display: flex;
                    align-items: center;
                    gap: 0.75rem;
                    flex-wrap: wrap;
                }

                .offer-modal-code-box {
                    font-family: ui-monospace, monospace;
                    font-size: 1.1rem;
                    font-weight: 700;
                    color: var(--primary-color, #4f46e5);
                    border: 2px dashed var(--primary-color, #4f46e5);
                    padding: 0.5rem 1rem;
                    border-radius: 8px;
                    letter-spacing: 0.12em;
                    text-transform: uppercase;
                    background: color-mix(in srgb, var(--primary-color, #4f46e5), transparent 92%);
                }

                .offer-modal-copy-btn {
                    display: flex;
                    align-items: center;
                    gap: 0.4rem;
                    background: var(--primary-color, #4f46e5);
                    color: white;
                    border: none;
                    border-radius: 8px;
                    padding: 0.5rem 1rem;
                    font-size: 0.75rem;
                    font-weight: 700;
                    letter-spacing: 0.06em;
                    text-transform: uppercase;
                    cursor: pointer;
                    transition: opacity 0.15s;
                }

                .offer-modal-copy-btn:hover {
                    opacity: 0.85;
                }

                .offer-modal-actions {
                    margin-top: 0;
                }

                .offer-modal-get-deal-btn {
                    display: block;
                    text-align: center;
                    background: var(--primary-color, #4f46e5);
                    color: white !important;
                    text-decoration: none !important;
                    font-weight: 700;
                    font-size: 1rem;
                    padding: 0.85rem 2rem;
                    border-radius: 10px;
                    transition: opacity 0.15s;
                    letter-spacing: 0.01em;
                }

                .offer-modal-get-deal-btn:hover {
                    opacity: 0.88;
                }

                .offer-modal-expiry {
                    margin-top: 1rem;
                    text-align: center;
                    font-size: 0.8rem;
                    color: #9ca3af;
                }

                @media (max-width: 480px) {
                    .offer-modal-card {
                        padding: 2rem 1.25rem 1.5rem;
                    }
                }
            </style>