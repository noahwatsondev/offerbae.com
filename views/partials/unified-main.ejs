<main class="content">

    <!-- Hero Section -->
    <% if (typeof showHero !='undefined' && showHero) { %>
        <%- include('section-hero', { heroLetter: heroLetter, heroProducts: (typeof heroProducts !=='undefined' ?
            heroProducts : undefined) }) %>
            <% } %>

                <!-- Categories Section (Optional, per page context) -->
                <% if (typeof showCategories !='undefined' && showCategories) { %>
                    <%- include('categories') %>
                        <% } %>

                            <!-- Brands Grid Section -->
                            <% if (typeof showBrands !='undefined' && showBrands) { %>
                                <%- include('section-brands') %>
                                    <% } %>



                                        <!-- Products Grid Section -->
                                        <% if (typeof showProducts !='undefined' && showProducts) { %>
                                            <%- include('section-products') %>
                                                <% } %>

                                                    <!-- Offers Grid Section -->
                                                    <% if (typeof showOffers !='undefined' && showOffers) { %>
                                                        <%- include('section-offers') %>
                                                            <% } %>

                                                                <!-- Love Letters Grid Section -->
                                                                <% if (typeof showLoveLetters !='undefined' &&
                                                                    showLoveLetters) { %>
                                                                    <%- include('section-loveletters') %>
                                                                        <% } %>

                                                                            <!-- Product Details Section -->
                                                                            <% if (typeof showProductDetails
                                                                                !='undefined' && showProductDetails) {
                                                                                %>
                                                                                <%- include('section-product-details')
                                                                                    %>
                                                                                    <% } %>

                                                                                        <!-- Offer Details Section -->
                                                                                        <% if (typeof showOfferDetails
                                                                                            !='undefined' &&
                                                                                            showOfferDetails) { %>
                                                                                            <%- include('section-offer-details')
                                                                                                %>
                                                                                                <% } %>

</main>