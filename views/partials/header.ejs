<% if (typeof settings !='undefined' && settings.headerStyles) { %>
    <style>
        .header {
            <%- settings.headerStyles %>
        }
    </style>
    <% } %>
        <header class="header" id="header">
            <div class="header-main">
                <div class="header-logo" onclick="location.href='/'">
                    <% if (typeof settings !='undefined' && settings.logoUrl) { %>
                        <img src="<%= settings.logoUrl %>" alt="OfferBae Home" class="header-logo-img">
                        <% } %>
                            <span class="header-logo-text"
                                style="<%= (typeof settings != 'undefined' && settings.logoStyles) ? settings.logoStyles : '' %>">
                                <%= (typeof settings !='undefined' && settings.logoText) ? settings.logoText
                                    : 'OfferBae' %>
                            </span>
                </div>

                <nav class="header-nav" id="header-nav">
                    <a href="/brands" class="nav-link">Brands</a>
                    <a href="/products" class="nav-link">Products</a>
                    <a href="/offers" class="nav-link">Offers</a>
                    <a href="/loveletters" class="nav-link">Love Letters</a>
                </nav>

                <button type="button" class="mobile-menu-toggle" id="mobile-menu-toggle" aria-label="Toggle navigation">
                    <svg class="icon-hamburger" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                        stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                    </svg>
                    <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                        stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div class="header-search-container">
                <div class="global-search">
                    <button class="search-btn" aria-label="Search" id="global-search-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                    </button>
                    <input type="text" placeholder="Search brands, products, offers..." class="search-input"
                        id="search-input">
                    
                    <div class="search-engine-toggle">
                        <svg viewBox="0 0 24 24" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                        <input type="checkbox" id="use-google-search" title="Use Google Search">
                    </div>

                    <div id="search-results" class="search-results"></div>
                </div>
            </div>

            <%- include('categories') %>

            <!-- Hidden Google Custom Search Element -->
            <div style="visibility: hidden; position: absolute; top: -9999px; left: -9999px;">
                <script async src="https://cse.google.com/cse.js?cx=62304ae06cc994c7f"></script>
                <div class="gcse-search"></div>
            </div>

        </header>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const toggleBtn = document.getElementById('mobile-menu-toggle');
                const header = document.getElementById('header');
                if (toggleBtn && header) {
                    toggleBtn.addEventListener('click', () => {
                        header.classList.toggle('mobile-nav-open');
                    });
                }

                const searchInput = document.getElementById('search-input');
                const searchToggle = document.getElementById('use-google-search');
                const searchBtn = document.getElementById('global-search-btn');

                function triggerSearch() {
                    const query = searchInput.value.trim();
                    if (!query) return;

                    if (searchToggle.checked) {
                        // Trigger Google Search
                        const gInput = document.querySelector('input.gsc-input');
                        const gBtn = document.querySelector('button.gsc-search-button');
                        if (gInput && gBtn) {
                            gInput.value = query;
                            gBtn.click();
                        } else {
                            console.warn("Google Custom Search not yet loaded.");
                        }
                    } else {
                        // Standard OfferBae Search Logic happens in public JS scripts.
                        // We will dispatch a custom event or let standard listeners handle it.
                        // Currently public search scripts listen to "input" events for dropdown.
                        // If there is an enter key submission we can do something here.
                    }
                }

                if (searchInput) {
                    searchInput.addEventListener('keydown', (e) => {
                        if (e.key === 'Enter') {
                            triggerSearch();
                        }
                    });
                }
                
                if (searchBtn) {
                    searchBtn.addEventListener('click', (e) => {
                        if (searchToggle.checked) {
                            e.preventDefault();
                            e.stopPropagation();
                            triggerSearch();
                        }
                    });
                }
            });
        </script>
