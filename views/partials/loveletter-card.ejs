<a href="/loveletters/<%= article.slug %>-<%= article.id %>" class="loveletter-card" style="text-decoration: none;">
    <% if (article.featuredImage) { %>
        <div class="card-image">
            <img src="<%= article.featuredImage %>" alt="<%= article.title %>">
        </div>
        <% } %>
            <div class="card-content">
                <span class="card-date">
                    <%= article.publishedAt ? new Date(article.publishedAt).toLocaleDateString(undefined, {
                        month: 'short' , day: 'numeric' , year: 'numeric' }) : 'Draft' %>
                </span>
                <h3>
                    <%= article.title %>
                </h3>
                <p>
                    <%= article.excerpt || '' %>
                </p>
                <span class="read-more">Read Letter →</span>
            </div>
</a>

<style>
    .loveletter-card {
        background: var(--surface, #fff);
        border: 1px solid var(--border, #e2e8f0);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
    }

    .loveletter-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.06);
        border-color: var(--primary-color);
    }

    .loveletter-card .card-image {
        aspect-ratio: 16/9;
        overflow: hidden;
    }

    .loveletter-card .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s;
    }

    .loveletter-card:hover .card-image img {
        transform: scale(1.05);
    }

    .loveletter-card .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .loveletter-card .card-date {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-secondary, #64748b);
        margin-bottom: 0.5rem;
    }

    .loveletter-card h3 {
        margin: 0 0 0.75rem 0;
        font-size: 1.25rem;
        font-weight: 800;
        line-height: 1.3;
    }

    .loveletter-card h3 a {
        color: var(--text-main, #0f172a);
        text-decoration: none;
    }

    .loveletter-card p {
        font-size: 0.95rem;
        color: var(--text-secondary, #64748b);
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .loveletter-card .read-more {
        margin-top: auto;
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--primary-color, #4f46e5);
        text-decoration: none;
    }
</style>