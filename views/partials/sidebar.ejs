<aside class="sidebar" style="display:flex; flex-direction:column; gap:2rem;">
    <h2 style="margin:0 0 0.5rem 0; font-size:1.25rem; font-weight:800; color:var(--text-color, #1a1a2e);">More Shopping
        on OfferBae</h2>
    <!-- Render Newest Brands -->
    <% if (typeof sidebarData !=='undefined' && sidebarData.newestBrands && sidebarData.newestBrands.length> 0) { %>
        <div class="widget">
            <h3 style="margin-bottom:1rem; padding-bottom:0.5rem; border-bottom:1px solid #eee;">Newest Brands</h3>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:1.5rem;">
                <% sidebarData.newestBrands.forEach(brand=> { %>
                    <li>
                        <a href="/brands/<%= brand.slug %>"
                            style="display:flex; align-items:center; gap:1rem; text-decoration:none; color:inherit;">
                            <% if (brand.logoUrl) { %>
                                <div
                                    style="width:40px; height:40px; background:white; border-radius:50%; border:1px solid #eee; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                                    <img src="<%= brand.logoUrl %>" alt="<%= brand.name %>"
                                        style="max-width:100%; max-height:100%;">
                                </div>
                                <% } else { %>
                                    <div
                                        style="width:40px; height:40px; background:#f3f4f6; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:bold; color:#888;">
                                        <%= brand.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <% } %>
                                        <div>
                                            <div style="font-weight:bold;">
                                                <%= brand.name %>
                                            </div>
                                            <div style="font-size:0.875rem; color:#666;">
                                                <%= brand.count %> Items
                                            </div>
                                        </div>
                        </a>
                    </li>
                    <% }) %>
            </ul>
        </div>
        <% } %>

            <!-- Render Newest Products -->
            <% if (typeof sidebarData !=='undefined' && sidebarData.newestProducts && sidebarData.newestProducts.length>
                0) { %>
                <div class="widget">
                    <h3 style="margin-bottom:1rem; padding-bottom:0.5rem; border-bottom:1px solid #eee;">Newest Products
                    </h3>
                    <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:1.5rem;">
                        <% sidebarData.newestProducts.forEach(product=> { %>
                            <li>
                                <!-- Fallback URL logic until we add brandSlug dynamically upstream reliably -->
                                <a href="/products/<%= product.slug %>"
                                    style="display:flex; align-items:center; gap:1rem; text-decoration:none; color:inherit;">
                                    <% if (product.imageUrl) { %>
                                        <div
                                            style="width:50px; height:50px; background:#f9fafb; border-radius:0.5rem; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                                            <img src="<%= product.imageUrl %>" alt="<%= product.name %>"
                                                style="max-width:100%; max-height:100%; object-fit:contain;">
                                        </div>
                                        <% } %>
                                            <div style="flex:1;">
                                                <div
                                                    style="font-weight:bold; font-size:0.9rem; line-height:1.2; display:-webkit-box; -webkit-line-clamp:2; line-clamp: 2; -webkit-box-orient:vertical; overflow:hidden;">
                                                    <%= product.name %>
                                                </div>
                                                <% const sOriginalPrice=Number(product.price || 0); const
                                                    sSalePrice=Number(product.salePrice || 0); const
                                                    sDisplayPrice=(sSalePrice> 0) ? sSalePrice : sOriginalPrice;
                                                    %>
                                                    <div
                                                        style="font-size:0.875rem; color:var(--color-green); font-weight:bold; margin-top:0.25rem;">
                                                        $<%= sDisplayPrice.toFixed(2) %>
                                                    </div>
                                            </div>
                                </a>
                            </li>
                            <% }) %>
                    </ul>
                </div>
                <% } %>

                    <!-- Render Newest Offers -->
                    <% if (typeof sidebarData !=='undefined' && sidebarData.newestOffers &&
                        sidebarData.newestOffers.length> 0) { %>
                        <div class="widget">
                            <h3 style="margin-bottom:1rem; padding-bottom:0.5rem; border-bottom:1px solid #eee;">Newest
                                Offers</h3>
                            <div style="display:flex; flex-direction:column; gap:1rem;">
                                <% sidebarData.newestOffers.forEach(offer=> { %>
                                    <%- include('offer-card', { offer, compact: true }) %>
                                        <% }) %>
                            </div>
                        </div>
                        <% } %>
</aside>