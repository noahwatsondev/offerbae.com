<section class="content-section">
    <div class="section-header">
        <div class="section-title-area">
            <h2 id="products-section-title">
                <%= typeof productsH2 !=='undefined' ? productsH2 : 'Top Products' %>
            </h2>
            <% if (typeof productsDescription !=='undefined' ) { %>
                <p class="section-description">
                    <%= productsDescription %>
                </p>
                <% } %>
        </div>
        <div class="section-actions">
            <% if (typeof showProductsFilters !=='undefined' && showProductsFilters) { %>
                <div class="section-filters">
                    <select class="select-mini">
                        <option>Sort by: Popular</option>
                        <option>Sort by: Discount</option>
                    </select>
                </div>
                <% } %>
                    <% if (typeof showProductsLink !=='undefined' && showProductsLink) { %>
                        <a href="/products" class="section-link">See All Products &rarr;</a>
                        <% } %>
        </div>
    </div>
    <div class="product-grid">
        <% if (typeof products !=='undefined' && products.length> 0) { %>
            <% products.forEach(product=> { %>
                <%- include('product-card', { product }) %>
                    <% }) %>
                        <% } else { %>
                            <p>No products found.</p>
                            <% } %>
    </div>
    <% if (typeof showProductsPagination !=='undefined' && showProductsPagination) { %>
        <% if (typeof hasMore !=='undefined' && hasMore) { %>
            <div class="load-more-container">
                <a href="?page=<%= (typeof currentPage !== 'undefined' ? currentPage : 1) + 1 %>"
                    class="btn-load-more">Next Page</a>
            </div>
            <% } %>
                <% } %>
</section>