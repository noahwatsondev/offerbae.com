<a href="/brands/<%= brand.slug %>" class="brand-card-wrapper" <% if (typeof showSortData !='undefined' &&
    showSortData) { %>
    data-name="<%= brand.name.toLowerCase() %>"
        data-stats-total="<%= (brand.productCount || 0) + (brand.offerCount || 0) %>"
            data-products="<%= brand.productCount || 0 %>"
                data-offers="<%= brand.offerCount || 0 %>"
                    <% } %>
                        >
                        <article class="brand-card">
                            <% if (brand.logoUrl) { %>
                                <div class="brand-logo"
                                    style="background-image: url('<%= brand.logoUrl %>'); background-size: contain; background-repeat: no-repeat; background-position: center; background-color: transparent;"
                                    role="img" aria-label="<%= brand.name %> Logo">
                                </div>
                                <% } else { %>
                                    <div class="brand-logo"></div>
                                    <% } %>

                                        <div class="brand-name">
                                            <%= brand.name %>
                                        </div>

                                        <div class="brand-meta">
                                            <div class="brand-stats-grid">
                                                <% const _hasProducts=(brand.productCount || 0)> 0; %>
                                                    <% const _hasOffers=(brand.offerCount || 0)> 0; %>
                                                        <% if (_hasProducts) { %>
                                                            <div class="stat-row">
                                                                <div class="stat-count"><strong>
                                                                        <%= brand.productCount %>
                                                                    </strong></div>
                                                                <div class="stat-label"><%= brand.productCount === 1 ? 'Item' : 'Items' %></div>
                                                                <div class="stat-tags">
                                                                    <% if (brand.saleProductCount> 0) { %><span
                                                                            class="sale-label">Sale</span>
                                                                        <% } %>
                                                                </div>
                                                            </div>
                                                            <% } %>
                                                                <% if (_hasProducts && _hasOffers) { %>
                                                                    <div class="stat-divider"></div>
                                                                    <% } %>
                                                                        <% if (_hasOffers) { %>
                                                                            <div class="stat-row">
                                                                                <div class="stat-count"><strong>
                                                                                        <%= brand.offerCount %>
                                                                                    </strong></div>
                                                                                <div class="stat-label"><%= brand.offerCount === 1 ? 'Deal' : 'Deals' %></div>
                                                                                <div class="stat-tags">
                                                                                    <% if (brand.hasPromoCodes) { %>
                                                                                        <span
                                                                                            class="codes-label">Codes</span>
                                                                                        <% } %>
                                                                                </div>
                                                                            </div>
                                                                            <% } %>
                                            </div>
                                            <% if (brand.categories && brand.categories.length> 0) { %>
                                                <div class="brand-categories">
                                                    <% const cats=typeof categoryLimit !='undefined' ?
                                                        brand.categories.slice(0, categoryLimit) : brand.categories;
                                                        cats.forEach(cat=> {
                                                        %>
                                                        <span class="category-pill"
                                                            style="font-size: 0.65rem; padding: 2px 8px;">
                                                            <%= cat %>
                                                        </span>
                                                        <% }) %>
                                                </div>
                                                <% } %>
                                        </div>
                                        <div class="brand-shop-cta">Browse store →</div>
                        </article>
</a>