<% if (typeof settings !='undefined' && settings.footerStyles) { %>
    <style>
        .footer {
            <%- settings.footerStyles %>
        }
    </style>
    <% } %>
        <footer class="footer">
            <div class="footer__container">
                <!-- Logo Section -->
                <div class="footer__logo-section">
                    <% if (typeof settings !='undefined' && settings.logoUrl) { %>
                        <img src="<%= settings.logoUrl %>" alt="OfferBae Logo" class="footer__logo-img">
                        <% } %>
                            <div class="footer__logo-text"
                                style="<%= (typeof settings != 'undefined' && settings.logoStyles) ? settings.logoStyles : '' %>color: white;">
                                <%= (typeof settings !='undefined' && settings.logoText) ? settings.logoText
                                    : 'OfferBae' %>
                            </div>
                </div>

                <!-- Footer Nav -->
                <nav class="footer__nav">
                    <a href="/brands" class="footer__nav-link">Brands</a>
                    <a href="/products" class="footer__nav-link">Products</a>
                    <a href="/offers" class="footer__nav-link">Offers</a>
                </nav>

                <!-- Copyright -->
                <p class="footer__copyright">&copy; 2026 OfferBae. All rights reserved.</p>

                <!-- Legal Links -->
                <div class="footer__legal">
                    <a href="/how-we-review-deals" class="footer__legal-link">How We Review Deals</a>
                    <a href="/legal" class="footer__legal-link">Legal Statement</a>
                    <a href="/privacy" class="footer__legal-link">Privacy Policy</a>
                    <a href="/terms" class="footer__legal-link">Terms of Use</a>
                </div>
            </div>
        </footer>