<% if (typeof brand !== 'undefined' && brand) { %>
<%
  const _sq = typeof searchQuery !== 'undefined' ? searchQuery : '';
  const _st = typeof searchType !== 'undefined' ? searchType : 'all';
  const _hasSearch = _sq || _st !== 'all';
%>
<section class="brand-search-section" id="brand-search-section">
    <form class="brand-search-bar-wrap" method="GET" action="/brands/<%= brand.slug %>" id="brand-search-form">

        <!-- Hidden type field, updated by pill buttons -->
        <input type="hidden" name="type" id="brand-search-type" value="<%= _st %>">

        <div class="brand-search-input-wrap">
            <svg class="brand-search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            <input
                type="text"
                name="bq"
                id="brand-search-input"
                class="brand-search-input"
                placeholder="Search products & offers..."
                autocomplete="off"
                value="<%= _sq %>"
            />
            <button type="submit" class="brand-search-submit" aria-label="Search">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                Search
            </button>
            <% if (_hasSearch) { %>
            <a href="/brands/<%= brand.slug %>" class="brand-search-clear-link" aria-label="Clear search">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </a>
            <% } %>
        </div>

        <div class="brand-search-filters">
            <button type="button" class="brand-filter-btn<%= _st === 'all' ? ' active' : '' %>" data-type="all" id="filter-all">All</button>
            <button type="button" class="brand-filter-btn<%= _st === 'products' ? ' active' : '' %>" data-type="products" id="filter-products">Products</button>
            <button type="button" class="brand-filter-btn<%= _st === 'offers' ? ' active' : '' %>" data-type="offers" id="filter-offers">Offers</button>
        </div>

        <% if (_hasSearch) { %>
        <div class="brand-search-status" id="brand-search-status">
            <% if (_sq) { %>
                <strong><%= typeof searchTotal !== 'undefined' ? searchTotal : '' %></strong> result<%= (typeof searchTotal !== 'undefined' && searchTotal !== 1) ? 's' : '' %> for &ldquo;<%= _sq %>&rdquo;<% if (_st !== 'all') { %> &mdash; <% } %>
            <% } %>
            <% if (_st !== 'all') { %><span class="search-tag"><%= _st %></span><% } %>
            &ensp;<a href="/brands/<%= brand.slug %>" class="search-clear-all">Clear all</a>
        </div>
        <% } %>

    </form>
</section>

<style>
.brand-search-section {
    padding: 0.5rem 0;
}
.brand-search-bar-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}
.brand-search-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.brand-search-icon {
    position: absolute;
    left: 1rem;
    color: #9ca3af;
    pointer-events: none;
    z-index: 1;
}
.brand-search-input {
    flex: 1;
    padding: 0.75rem 2.75rem 0.75rem 2.75rem;
    border: 1.5px solid #e5e7eb;
    border-radius: 12px;
    font-size: 0.975rem;
    font-family: inherit;
    background: #fff;
    color: #111827;
    transition: border-color 0.18s, box-shadow 0.18s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    outline: none;
    min-width: 0;
}
.brand-search-input:focus {
    border-color: var(--color-violet, #7c3aed);
    box-shadow: 0 0 0 3px rgba(124,58,237,0.12);
}
.brand-search-submit {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.72rem 1.2rem;
    background: var(--color-violet, #7c3aed);
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
    box-shadow: 0 2px 8px rgba(124,58,237,0.18);
    white-space: nowrap;
}
.brand-search-submit:hover {
    background: #6d28d9;
    box-shadow: 0 4px 14px rgba(124,58,237,0.28);
}
.brand-search-submit:active {
    transform: scale(0.97);
}
.brand-search-clear-link {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #f3f4f6;
    color: #6b7280;
    border: 1.5px solid #e5e7eb;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
}
.brand-search-clear-link:hover { color: #374151; background: #e5e7eb; }
.brand-search-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
}
.brand-filter-btn {
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    border: 1.5px solid #e5e7eb;
    background: #fff;
    color: #374151;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
}
.brand-filter-btn:hover { border-color: #a78bfa; color: #5b21b6; }
.brand-filter-btn.active {
    background: var(--color-violet, #7c3aed);
    border-color: var(--color-violet, #7c3aed);
    color: #fff;
}
.brand-filter-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: #374151;
    cursor: pointer;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    border: 1.5px solid #e5e7eb;
    background: #fff;
    transition: all 0.15s;
    user-select: none;
}
.brand-filter-toggle:has(input:checked) {
    border-color: var(--color-violet, #7c3aed);
    background: rgba(124,58,237,0.08);
    color: #5b21b6;
}
.brand-filter-toggle:hover { border-color: #a78bfa; color: #5b21b6; }
.brand-filter-toggle input[type=checkbox] { accent-color: var(--color-violet, #7c3aed); width: 14px; height: 14px; }
.brand-search-status {
    font-size: 0.84rem;
    color: #6b7280;
    padding: 0.2rem 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
}
.search-tag {
    display: inline-flex;
    align-items: center;
    background: rgba(124,58,237,0.1);
    color: #5b21b6;
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
    font-weight: 600;
    font-size: 0.78rem;
    text-transform: capitalize;
}
.search-clear-all {
    color: #9ca3af;
    font-size: 0.78rem;
    text-decoration: underline;
    text-underline-offset: 2px;
}
.search-clear-all:hover { color: #374151; }
</style>

<script>
(function() {
    // Pill buttons update the hidden type field and auto-submit
    const typeInput = document.getElementById('brand-search-type');
    const form = document.getElementById('brand-search-form');
    document.querySelectorAll('.brand-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.brand-filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            typeInput.value = btn.dataset.type;
            form.submit();
        });
    });



    // Allow Enter key on input to submit
    const input = document.getElementById('brand-search-input');
    if (input) {
        input.addEventListener('keydown', e => {
            if (e.key === 'Enter') { e.preventDefault(); form.submit(); }
        });
    }
})();
</script>
<% } %>
